{
  "manifest_version": 3,
  "name": "Soopzzk Multiview",
  "version": "1.1.0",
  "description": "숲/치지직 멀티뷰에서 로그인 쿠키와 채널 정보를 사용할 수 있게 해주는 확장 프로그램",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "*://*.github.io/*",
    "*://*.ruby747.com/*",
    "*://*.naver.com/*",
    "*://*.chzzk.naver.com/*",
    "*://*.sooplive.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://ruby747.github.io/soopzzk/*",
        "*://www.ruby747.com/soopzzk/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
